{
  "name": "check-storybook",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@babel/core": "^7.12.10",
    "@mdx-js/react": "^1.6.22",
    "@storybook/addon-actions": "^6.1.11",
    "@storybook/addon-docs": "^6.1.11",
    "@storybook/addon-essentials": "^6.1.11",
    "@storybook/addon-links": "^6.1.11",
    "@storybook/react": "^6.1.11",
    "babel-loader": "^8.2.2",
    "core-js": "^3.8.2",
    "gh-pages": "^3.1.0",
    "react": "^17.0.1",
    "react-dom": "^17.0.1"
  },
  "scripts": {
    "generate-atoms-stories": "npx sb extract build/storybook/atoms",
    "generate-molecules-stories": "npx sb extract build/storybook/molecules",
    "build-stories": "build-storybook -o build/storybook/main",
    "generate-stories": "npx sb extract build/storybook/main",
    "deploy-storybook": "gh-pages -d build/storybook/main --dest docs/story-main",
    "deploy-storybook-atoms": "gh-pages -d build/storybook/atoms --dest docs/story-atoms",
    "deploy-storybook-molecules": "gh-pages -d build/storybook/molecules --dest docs/story-molecules"
  }
}
